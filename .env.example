# Copy this to .env and fill in real values, OR run `make keys` to generate them.
# Both must be 32 bytes, hex-encoded (64 hex chars each).

VYOS_CP_SEAL_KEY=REPLACE_WITH_openssl_rand_hex_32
VYOS_CP_JWT_KEY=REPLACE_WITH_openssl_rand_hex_32

# Ship 1 — snapshot capture cadence (poller ticks between snapshots).
# At default poll interval 10s, 30 ticks = one snapshot per 5 minutes.
# Set 0 to disable periodic snapshots (manual POST and startup still work).
VYOS_CP_SNAPSHOT_INTERVAL_TICKS=30
