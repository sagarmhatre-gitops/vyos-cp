package translator

// IPsec translator. Mirrors the shape of translator/nat_zones.go:
// one Ops function per domain object that returns []vyos.ConfigureOp,
// one DeleteXOps that wipes the parent path, one DecodeX that parses
// the JSON returned by client.Retrieve(OpShowConfig, ...).
//
// VyOS reference paths (verified against 1.4 Sagitta / 1.5 Circinus):
//   vpn ipsec ike-group <name>
//     proposal <N> encryption <cipher>
//     proposal <N> hash <hash>
//     proposal <N> dh-group <group>
//     lifetime <sec>
//     key-exchange <ikev1|ikev2>
//     mode <main|aggressive>
//     dead-peer-detection { action interval timeout }
//   vpn ipsec esp-group <name>
//     proposal <N> encryption <cipher>
//     proposal <N> hash <hash>
//     lifetime <sec>
//     mode <tunnel|transport>
//     pfs <enable|disable|dh-groupN>
//   vpn ipsec site-to-site peer <peer-id>
//     remote-address <ip|fqdn|any>
//     local-address <ip|any>
//     ike-group <ref>
//     default-esp-group <ref>
//     authentication { mode <psk|rsa|x509> ... }
//     tunnel <N> { local prefix ... | remote prefix ... | esp-group <ref> ... }
//   vpn ipsec ipsec-interfaces interface <if>
//   vpn ipsec nat-traversal <enable|disable>

import (
	"encoding/json"
	"fmt"
	"sort"
	"strconv"

	"github.com/vyos-cp/vyos-cp/internal/model"
	"github.com/vyos-cp/vyos-cp/internal/vyos"
)

// --- Encode: IKE group -----------------------------------------------------

func IKEGroupOps(g model.IKEGroup) ([]vyos.ConfigureOp, error) {
	if g.Name == "" {
		return nil, fmt.Errorf("ike-group name required")
	}
	if len(g.Proposals) == 0 {
		return nil, fmt.Errorf("ike-group %q: at least one proposal required", g.Name)
	}
	base := []string{"vpn", "ipsec", "ike-group", g.Name}
	var ops []vyos.ConfigureOp
	leaf := func(val string, keys ...string) {
		if val != "" {
			ops = append(ops, vyos.ConfigureOp{Op: vyos.OpSet, Path: joinPath(base, keys...), Value: val})
		}
	}
	if g.Lifetime > 0 {
		leaf(strconv.Itoa(g.Lifetime), "lifetime")
	}
	leaf(g.IKEVersion, "key-exchange")
	if g.Mode != "" {
		leaf(string(g.Mode), "mode")
	}
	if g.DeadPeer != nil {
		dpd := []string{"dead-peer-detection"}
		if g.DeadPeer.Action != "" {
			leaf(string(g.DeadPeer.Action), append(dpd, "action")...)
		}
		if g.DeadPeer.Interval > 0 {
			leaf(strconv.Itoa(g.DeadPeer.Interval), append(dpd, "interval")...)
		}
		if g.DeadPeer.Timeout > 0 {
			leaf(strconv.Itoa(g.DeadPeer.Timeout), append(dpd, "timeout")...)
		}
	}
	for _, p := range g.Proposals {
		if p.Number < 1 || p.Number > 65535 {
			return nil, fmt.Errorf("ike-group %q proposal number %d out of range", g.Name, p.Number)
		}
		pb := []string{"proposal", strconv.Itoa(p.Number)}
		leaf(p.Encryption, append(pb, "encryption")...)
		leaf(p.Hash, append(pb, "hash")...)
		leaf(p.DHGroup, append(pb, "dh-group")...)
		leaf(p.PRF, append(pb, "prf")...)
	}
	return ops, nil
}

func DeleteIKEGroupOps(name string) []vyos.ConfigureOp {
	return []vyos.ConfigureOp{{Op: vyos.OpDelete, Path: []string{"vpn", "ipsec", "ike-group", name}}}
}

